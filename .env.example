# Supabase project URL — found in Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
# Supabase anon/public key — safe for client-side use
SUPABASE_ANON_KEY=your-anon-key-here
# Supabase service_role key — keep secret, used for admin operations
SUPABASE_SERVICE_KEY=your-service-role-key-here

REDIS_URL=redis://localhost:6379/0

# CORS allowed origins (comma-separated, no spaces)
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:5500,http://localhost:3000,http://localhost:5173

# GitHub credentials for Automated Issue Triage System
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret_here